# iOPEX Core Stack — Environment Variables
#
# Copy this file: cp .env.example .env
# Then fill in your actual values.
#
# Variables marked REQUIRED will cause docker compose to fail if missing.
# Variables with defaults (:-value) are optional.

# ── Database (REQUIRED) ─────────────────────────────────────────────
POSTGRES_PASSWORD=changeme                # Generate: openssl rand -hex 16
POSTGRES_USER=postgres                    # Default: postgres
POSTGRES_DB=iopex_expert                  # Default: iopex_expert

# ── LLM (REQUIRED) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # Claude API key — get at console.anthropic.com

# ── Telegram Bot (REQUIRED for bot container) ────────────────────────
TELEGRAM_BOT_TOKEN_IOPEX=...              # iOPEX master bot — get from @BotFather
# TELEGRAM_BOT_TOKEN_CLIENT_X=...         # White-label client bot (optional)

# ── Web Augmentation ─────────────────────────────────────────────────
TAVILY_API_KEY=                           # C-08: web fallback — free key at tavily.com (1k/mo)

# ── Confidence Tuning ────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.55                 # Below this → Tavily web augmentation
# OPENAI_API_KEY=sk-...                   # Backup embeddings (not primary — uses HuggingFace)

# ── Secret Source (C-06) ─────────────────────────────────────────────
USE_KEY_VAULT=false                       # Set true + AZURE_KEYVAULT_URL for production
# AZURE_KEYVAULT_URL=                     # Azure Key Vault URL (production only)

# ── SHIFT API (optional — for MCP Hub shift tools) ──────────────────
# SHIFT_API_URL=http://localhost:8000     # Default: falls back to digital-expert-api

# ── n8n (optional — docker compose --profile n8n) ────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme                     # Generate: openssl rand -hex 16

# ── Phase 3 — Avatar & Voice (add later) ─────────────────────────────
# HEYGEN_API_KEY=
# IOPEX_AVATAR_ID=
# IOPEX_VOICE_ID=
# WEBHOOK_BASE_URL=                       # Public HTTPS URL for HeyGen callbacks
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
